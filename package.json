{
  "name": "readbetter",
  "version": "0.0.1",
  "description": "Local-first spatial document reader",
  "license": "Apache-2.0",
  "scripts": {
    "dev": "vite --config vite.config.web.ts",
    "build": "npm run build:web && npm run build:server",
    "start": "npm run start:web",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build:web": "vite build --config vite.config.web.ts",
    "build:server": "vite build --config vite.config.server.ts",
    "start:web": "npm run build:web && npm run build:server && node out-server/start.mjs"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/node": "^20.19.43",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "jsdom": "^24.1.0",
    "typescript": "^5.5.0",
    "vite": "^5.3.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@llamaindex/liteparse": "^2.0.8",
    "pdfjs-dist": "^6.0.227",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  }
}
